{
    "tabWidth": 4,
    "printWidth": 200,
    "semi": true,
    "singleQuote": true,
    "bracketSameLine": true,
    "proseWrap": "never",
    "singleAttributePerLine": false,
    "htmlWhitespaceSensitivity": "css",
    "overrides": [
        {
            "files": "**/*.yml",
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": "**/*.toml",
            "options": {
                "tabWidth": 2
            }
        }
    ]
}